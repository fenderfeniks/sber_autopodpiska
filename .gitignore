# ============================================================
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.egg-info/
__pycache__/
*.pyc
*.gradio


# ============================================================
# TESTING (Pytest)
# ============================================================
