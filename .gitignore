__pycache__/
*.py[cod]
*$py.class

# Окружения (Conda / Virtualenv)
.venv/
venv/
env/
ENV/
conda-env/

# Системные файлы Windows / macOS
Thumbs.db
Desktop.ini
.DS_Store

